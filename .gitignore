# AI Skill Content Library files — keep directory structure, ignore user content
content-library/sources/*
content-library/topics/*
content-library/reports/*

# Keep .gitkeep placeholders so the directory structure is preserved
!content-library/sources/.gitkeep
!content-library/topics/.gitkeep
!content-library/reports/.gitkeep

# Index files should be included as they contain metadata
# content-library/index.json
# content-library/sources.json

# OS and IDE files
.DS_Store
.vscode/
.idea/

# Node/Python artifacts (if any)
__pycache__/
*.pyc
node_modules/
